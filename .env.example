# ==============================================================================
# ZenBuild environment variables
# Copy to `.env` at the repo root and fill in. Never commit `.env`.
# Grouped by the phase that first needs them.
# ==============================================================================

# --- Core / Phase 1 ------------------------------------------------------------
NODE_ENV=development
# Postgres connection string — single URL, used at runtime (driver adapter) and
# for Prisma migrations (prisma.config.ts).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Public base URL of the web app (http://localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth / Phase 2 (BetterAuth) ----------------------------------------------
# Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# GitHub OAuth App (for "Sign in with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI / Phase 4+ (OpenAI via AI SDK) ----------------------------------------
# The model is selected in code / per-request, not via env.
OPENAI_API_KEY=

# --- GitHub App / Phase 7 (repos, webhooks, PR comments) ----------------------
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# PEM private key. Keep newlines as literal \n in a single line, or use a file path.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Async / Phase 4+ (Inngest) -----------------------------------------------
# Local dev: leave blank and use the Inngest dev server. Cloud: fill both.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Billing / Phase 13 (Razorpay test mode) ----------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Observability / Phase 14 -------------------------------------------------
SENTRY_DSN=
