# ==============================================================================
# ZenBuild environment variables
# Copy to `.env` at the repo root and fill in. Never commit `.env`.
# Grouped by the phase that first needs them.
# ==============================================================================

# --- Core / Phase 1 ------------------------------------------------------------
NODE_ENV=development
# Postgres connection string — single URL, used at runtime (driver adapter) and
# for Prisma migrations (prisma.config.ts).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Public base URL of the web app (http://localhost:3000 in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth / Phase 2 (BetterAuth) ----------------------------------------------
# Generate: `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# GitHub OAuth App (for "Sign in with GitHub")
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Google OAuth (for "Sign in with Google")
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email / Phase 2 (Resend) -------------------------------------------------
# Transactional email (verification codes, welcome, invites). Leave RESEND_API_KEY
# blank in dev to log emails to the console instead of sending. EMAIL_FROM must be
# a sender on a domain you've verified in Resend.
RESEND_API_KEY=
EMAIL_FROM=ZenBuild <onboarding@resend.dev>

# --- AI / Phase 4+ (OpenAI via AI SDK) ----------------------------------------
# The model is selected in code / per-request, not via env.
OPENAI_API_KEY=

# --- GitHub App / Phase 7 (repos, webhooks, PR comments) ----------------------
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# PEM private key. Keep newlines as literal \n in a single line, or use a file path.
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Async / Phase 4+ (Inngest) -----------------------------------------------
# Local dev: leave blank and use the Inngest dev server. Cloud: fill both.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Billing / Phase 13 (Razorpay test mode) ----------------------------------
# Test-mode API keys from the Razorpay dashboard (Settings → API Keys). Leave
# blank to run the app on the Free plan only — the billing UI degrades to an
# "unconfigured" state and paid upgrades are hidden.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret you set on the Razorpay webhook (Settings → Webhooks). The
# endpoint is POST {NEXT_PUBLIC_APP_URL}/api/razorpay/webhook; subscribe to the
# subscription.* events.
RAZORPAY_WEBHOOK_SECRET=
# Subscription plan ids (Subscriptions → Plans) — one per paid tier. A tier with
# no plan id can't be subscribed to.
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_TEAM=
# The publishable key id, exposed to the browser Checkout. Same value as
# RAZORPAY_KEY_ID.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Observability / Phase 14 -------------------------------------------------
SENTRY_DSN=
